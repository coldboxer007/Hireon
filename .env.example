# ──────────────────────────────────────────────────────────────
# Hireeon — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# AWS Credentials (required)
# Create an IAM user with AmazonBedrockFullAccess policy,
# then generate access keys in the AWS Console.
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# AWS Region (required)
# Nova 2 Sonic only supports: us-east-1, us-west-2, ap-northeast-1, eu-north-1
# Nova 2 Lite supports all Bedrock regions.
# Recommended: us-east-1 (supports both models)
AWS_REGION="us-east-1"
AWS_DEFAULT_REGION="us-east-1"
